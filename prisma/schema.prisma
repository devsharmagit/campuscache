generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ROLE {
  USER
  ADMIN
}

enum ResourceType {
  PYQ
  SYLLABUS
  QUESTION_BANK
  NOTES
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      ROLE     @default(USER)

  resources Resource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String     @id @default(cuid())
  name      String     @unique

  resources Resource[]
}

model Year {
  id        String     @id @default(cuid())
  label     String     @unique

  resources Resource[]
}

model Semester {
  id        String     @id @default(cuid())
  number    Int        @unique

  resources Resource[]
}

model Subject {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique

  resources Resource[]
}

model Resource {
  id           String        @id @default(cuid())
  slug         String        @unique

  title        String
  fileUrl      String
  fileSize     Int?
  type         ResourceType

  subjectId    String
  semesterId   String
  yearId       String
  branchId     String
  uploadedById String?

  subject      Subject       @relation(fields: [subjectId], references: [id])
  semester     Semester      @relation(fields: [semesterId], references: [id])
  year         Year          @relation(fields: [yearId], references: [id])
  branch       Branch        @relation(fields: [branchId], references: [id])
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([subjectId])
  @@index([semesterId])
  @@index([yearId])
  @@index([branchId])
  @@index([type])

  @@unique([subjectId, semesterId, yearId, branchId, type, title])
}